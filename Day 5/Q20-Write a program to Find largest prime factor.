#include <stdio.h>

int main() {
    long long num;
    int i, largestPrimeFactor = 0;

    printf("Enter a number: ");
    scanf("%lld", &num);

    for(i = 2; i <= num; i++) {
        while(num % i == 0) {
            largestPrimeFactor = i;
            num = num / i;
        }
    }

    printf("Largest Prime Factor = %d\n", largestPrimeFactor);

    return 0;
}
