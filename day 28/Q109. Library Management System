#include <stdio.h>
#include <string.h>

struct Book
{
    int id;
    char name[50];
    char author[50];
};

int main()
{
    struct Book b[100];
    int n = 0, choice, i, id, found;

    while (1)
    {
        printf("\n----- Library Management System -----\n");
        printf("1. Add Book\n");
        printf("2. Display Books\n");
        printf("3. Search Book\n");
        printf("4. Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);

        switch (choice)
        {
        case 1:
            printf("Book ID: ");
            scanf("%d", &b[n].id);

            printf("Book Name: ");
            scanf(" %[^\n]", b[n].name);

            printf("Author: ");
            scanf(" %[^\n]", b[n].author);

            n++;
            printf("Book Added Successfully!\n");
            break;

        case 2:
            printf("\nBooks List\n");
            for (i = 0; i < n; i++)
            {
                printf("\nID: %d", b[i].id);
                printf("\nName: %s", b[i].name);
                printf("\nAuthor: %s\n", b[i].author);
            }
            break;

        case 3:
            printf("Enter Book ID: ");
            scanf("%d", &id);

            found = 0;
            for (i = 0; i < n; i++)
            {
                if (b[i].id == id)
                {
                    printf("\nBook Found\n");
                    printf("Name: %s\n", b[i].name);
                    printf("Author: %s\n", b[i].author);
                    found = 1;
                }
            }

            if (!found)
                printf("Book Not Found\n");
            break;

        case 4:
            return 0;

        default:
            printf("Invalid Choice\n");
        }
    }
}
