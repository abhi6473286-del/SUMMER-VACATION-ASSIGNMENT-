#include <stdio.h>

int main()
{
    int vote;
    int candidate1 = 0, candidate2 = 0, candidate3 = 0;
    int n, i;

    printf("===== Voting System =====\n");
    printf("Enter number of voters: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++)
    {
        printf("\nVoter %d\n", i);
        printf("1. Candidate A\n");
        printf("2. Candidate B\n");
        printf("3. Candidate C\n");
        printf("Enter your vote: ");
        scanf("%d", &vote);

        switch(vote)
        {
            case 1:
                candidate1++;
                break;

            case 2:
                candidate2++;
                break;

            case 3:
                candidate3++;
                break;

            default:
                printf("Invalid Vote!\n");
        }
    }

    printf("\n===== Result =====\n");
    printf("Candidate A = %d votes\n", candidate1);
    printf("Candidate B = %d votes\n", candidate2);
    printf("Candidate C = %d votes\n", candidate3);

    return 0;
}
