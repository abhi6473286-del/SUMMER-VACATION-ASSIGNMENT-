#include <stdio.h>

int main()
{
    int answer;
    int score = 0;

    printf("===== Simple Quiz =====\n");

    printf("\nQ1. Capital of India?\n");
    printf("1. Mumbai\n2. Delhi\n3. Chennai\n4. Kolkata\n");
    scanf("%d", &answer);

    if(answer == 2)
        score++;

    printf("\nQ2. 5 + 7 = ?\n");
    printf("1. 10\n2. 11\n3. 12\n4. 13\n");
    scanf("%d", &answer);

    if(answer == 3)
        score++;

    printf("\nQ3. Which language is used for system programming?\n");
    printf("1. C\n2. HTML\n3. CSS\n4. SQL\n");
    scanf("%d", &answer);

    if(answer == 1)
        score++;

    printf("\nQ4. Which planet is called the Red Planet?\n");
    printf("1. Earth\n2. Venus\n3. Mars\n4. Jupiter\n");
    scanf("%d", &answer);

    if(answer == 3)
        score++;

    printf("\nQ5. Which symbol is used for comments in C (single line)?\n");
    printf("1. //\n2. ##\n3. <!-- -->\n4. **\n");
    scanf("%d", &answer);

    if(answer == 1)
        score++;

    printf("\n=========================\n");
    printf("Your Score = %d/5\n", score);

    if(score == 5)
        printf("Excellent!\n");
    else if(score >= 3)
        printf("Good Job!\n");
    else
        printf("Keep Practicing!\n");

    return 0;
}
